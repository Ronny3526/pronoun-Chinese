<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luyện Phát Âm Tiếng Trung Toàn Diện</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #3B82F6; /* Đổi sang màu xanh dương thân thiện, học thuật */
            --primary-hover: #2563EB;
            --bg-color: #F3F4F6;
            --card-bg: #FFFFFF;
            --text-main: #1F2937;
            --text-muted: #6B7280;
            --border-color: #E5E7EB;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Quicksand', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .app-container {
            background-color: var(--card-bg);
            width: 100%;
            max-width: 450px;
            border-radius: 24px;
            padding: 30px 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            text-align: center;
        }

        /* Phần chọn bài học */
        .lesson-selector {
            margin-bottom: 25px;
        }
        
        select {
            width: 100%;
            padding: 12px 15px;
            border-radius: 12px;
            border: 2px solid var(--border-color);
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-main);
            background-color: #F9FAFB;
            cursor: pointer;
            outline: none;
            transition: border-color 0.3s;
        }

        select:focus {
            border-color: var(--primary-color);
        }

        /* Khu vực hiển thị từ vựng */
        .word-display {
            margin-bottom: 30px;
            padding: 20px;
            border-radius: 16px;
            background-color: #F0F9FF;
            border: 1px solid #BAE6FD;
        }

        .hanzi {
            font-size: 5.5rem;
            font-weight: 700;
            line-height: 1.2;
            color: var(--primary-color);
        }

        .pinyin {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--text-main);
            letter-spacing: 2px;
            margin-bottom: 5px;
        }

        .meaning {
            font-size: 1rem;
            color: var(--text-muted);
            font-style: italic;
        }

        /* Các nút điều hướng */
        .navigation {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .nav-btn {
            background-color: transparent;
            border: 1px solid var(--border-color);
            padding: 10px 20px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s;
        }

        .nav-btn:hover:not(:disabled) {
            background-color: #F3F4F6;
            color: var(--text-main);
        }
        
        .nav-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Nút thu âm */
        .record-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 16px 40px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
            width: 100%;
        }

        .record-btn:hover {
            background-color: var(--primary-hover);
        }

        .record-btn.recording {
            background-color: #EF4444;
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
            animation: pulse 1.5s infinite;
        }

        .feedback-area {
            margin-top: 25px;
            padding: 15px;
            border-radius: 12px;
            background-color: #F9FAFB;
            display: none;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            70% { box-shadow: 0 0 0 15px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="lesson-selector">
            <select id="topicSelect">
                <option value="tones">Bài 1: Luyện 4 thanh điệu cơ bản</option>
                <option value="vowels">Bài 2: Vận mẫu đơn (a, o, e, i, u, ü)</option>
                <option value="hardConsonants">Bài 3: Phân biệt z/c/s và zh/ch/sh</option>
                <option value="greetings">Bài 4: Chào hỏi cơ bản</option>
            </select>
        </div>

        <main>
            <div class="word-display">
                <div class="hanzi" id="displayHanzi">妈</div>
                <div class="pinyin" id="displayPinyin">mā</div>
                <div class="meaning" id="displayMeaning">(mẹ)</div>
            </div>

            <div class="navigation">
                <button class="nav-btn" id="prevBtn" disabled>⬅ Trước</button>
                <span style="align-self: center; font-weight: 600; color: #6B7280;" id="counter">1/4</span>
                <button class="nav-btn" id="nextBtn">Sau ➡</button>
            </div>

            <button class="record-btn" id="recordBtn">🎤 Nhấn để đọc thử</button>

            <div class="feedback-area" id="feedbackArea">
                <p style="font-size: 1.1rem; font-weight: 700;" id="feedbackText">Đang phân tích...</p>
                <p style="font-size: 0.9rem; color: #4B5563; margin-top: 8px;" id="feedbackDetail"></p>
            </div>
        </main>
    </div>

    <script>
        // Cấu trúc dữ liệu bài học (Curriculum Database)
        const database = {
            tones: [
                { hanzi: '妈', pinyin: 'mā', meaning: 'mẹ (Thanh 1: Ngang, cao)' },
                { hanzi: '麻', pinyin: 'má', meaning: 'cây gai (Thanh 2: Đi lên giống dấu sắc)' },
                { hanzi: '马', pinyin: 'mǎ', meaning: 'con ngựa (Thanh 3: Xuống rồi lên giống dấu hỏi)' },
                { hanzi: '骂', pinyin: 'mà', meaning: 'mắng (Thanh 4: Rơi dứt khoát)' }
            ],
            vowels: [
                { hanzi: '阿', pinyin: 'ā', meaning: 'a (Mở to miệng)' },
                { hanzi: '哦', pinyin: 'ó', meaning: 'ồ (Tròn môi)' },
                { hanzi: '饿', pinyin: 'è', meaning: 'đói (Môi hơi dẹt)' },
                { hanzi: '一', pinyin: 'yī', meaning: 'số một (Răng khép nhẹ)' }
            ],
            hardConsonants: [
                { hanzi: '早', pinyin: 'zǎo', meaning: 'sớm (Đầu lưỡi chạm răng)' },
                { hanzi: '草', pinyin: 'cǎo', meaning: 'cỏ (Bật hơi mạnh)' },
                { hanzi: '中', pinyin: 'zhōng', meaning: 'ở giữa (Uốn lưỡi)' },
                { hanzi: '吃', pinyin: 'chī', meaning: 'ăn (Uốn lưỡi + bật hơi)' }
            ],
            greetings: [
                { hanzi: '你好', pinyin: 'nǐ hǎo', meaning: 'xin chào' },
                { hanzi: '谢谢', pinyin: 'xiè xie', meaning: 'cảm ơn' },
                { hanzi: '再见', pinyin: 'zài jiàn', meaning: 'tạm biệt' }
            ]
        };

        // Các biến trạng thái UI
        let currentTopic = 'tones';
        let currentIndex = 0;
        let isRecording = false;

        // Lấy các element từ DOM
        const topicSelect = document.getElementById('topicSelect');
        const displayHanzi = document.getElementById('displayHanzi');
        const displayPinyin = document.getElementById('displayPinyin');
        const displayMeaning = document.getElementById('displayMeaning');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const counter = document.getElementById('counter');
        const recordBtn = document.getElementById('recordBtn');
        const feedbackArea = document.getElementById('feedbackArea');
        const feedbackText = document.getElementById('feedbackText');
        const feedbackDetail = document.getElementById('feedbackDetail');

        // Hàm cập nhật giao diện khi đổi từ vựng
        function updateDisplay() {
            const currentList = database[currentTopic];
            const currentWord = currentList[currentIndex];

            displayHanzi.innerText = currentWord.hanzi;
            displayPinyin.innerText = currentWord.pinyin;
            displayMeaning.innerText = `(${currentWord.meaning})`;
            
            counter.innerText = `${currentIndex + 1}/${currentList.length}`;

            // Ẩn kết quả cũ
            feedbackArea.style.display = 'none';
            recordBtn.innerHTML = '🎤 Nhấn để đọc thử';
            
            // Xử lý trạng thái nút điều hướng
            prevBtn.disabled = currentIndex === 0;
            nextBtn.disabled = currentIndex === currentList.length - 1;
        }

        // Lắng nghe sự kiện đổi chủ đề
        topicSelect.addEventListener('change', (e) => {
            currentTopic = e.target.value;
            currentIndex = 0; // Reset về từ đầu tiên của chủ đề mới
            updateDisplay();
        });

        // Điều hướng Trước/Sau
        prevBtn.addEventListener('click', () => {
            if (currentIndex > 0) {
                currentIndex--;
                updateDisplay();
            }
        });

        nextBtn.addEventListener('click', () => {
            if (currentIndex < database[currentTopic].length - 1) {
                currentIndex++;
                updateDisplay();
            }
        });

        // Xử lý thu âm (Mô phỏng)
        recordBtn.addEventListener('click', () => {
            if (!isRecording) {
                isRecording = true;
                recordBtn.classList.add('recording');
                recordBtn.innerHTML = '🛑 Đang nghe...';
                feedbackArea.style.display = 'none';
                
                setTimeout(() => stopRecording(), 2500);
            } else {
                stopRecording();
            }
        });

        function stopRecording() {
            isRecording = false;
            recordBtn.classList.remove('recording');
            recordBtn.innerHTML = '🎤 Nghe lại lần nữa';
            
            // Random kết quả để tạo cảm giác app đang hoạt động thật
            const scores = [
                { color: '#10B981', bg: '#ECFDF5', title: 'Xuất sắc! (98đ)', detail: 'Phát âm rất rõ ràng, thanh điệu chuẩn xác.' },
                { color: '#F59E0B', bg: '#FFFBEB', title: 'Khá tốt! (75đ)', detail: 'Gần chuẩn rồi, chú ý ngân dài giọng hơn một chút nhé.' },
                { color: '#3B82F6', bg: '#EFF6FF', title: 'Tốt! (85đ)', detail: 'Pinyin đọc đúng, nhưng chú ý khẩu hình miệng.' }
            ];
            
            const randomResult = scores[Math.floor(Math.random() * scores.length)];

            feedbackArea.style.display = 'block';
            feedbackArea.style.backgroundColor = randomResult.bg;
            feedbackText.style.color = randomResult.color;
            feedbackText.innerText = randomResult.title;
            feedbackDetail.innerText = randomResult.detail;
        }

        // Khởi tạo app lần đầu chạy
        updateDisplay();
    </script>
</body>
</html>
